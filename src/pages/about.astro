import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — Jakob Højgaard">
  <div class="animate-fade-in py-20 max-w-[640px]">
    <p class="font-body text-sm text-accent tracking-[2px] uppercase mb-5 font-medium">About</p>
    <h1 class="font-display text-4xl md:text-[48px] font-semibold text-text-primary leading-[1.1] tracking-tight mb-8">
      Jakob Højgaard
    </h1>

    <div class="prose">
      <p>
        I'm a Danish technologist living on the Sunshine Coast in Queensland, Australia, and the
        founder of <strong class="text-text-primary font-semibold"><a href="https://guidy.au" class="!text-text-primary !no-underline">Guidy</a></strong> — an end-to-end companion for everyday Australian first
        home buyers. They want real guidance and they go looking for it, yet the traditional model
        serves them last, because they take the most time.
      </p>

      <p>
        This generation doesn't learn about mortgages at the kitchen table — they learn online, at
        11pm — and Guidy is built to be the knowledgeable presence they don't otherwise have:
        helping them navigate HECS debt, smaller deposits, guarantors, and government schemes, from
        the first question through to keys in hand.
      </p>

      <p>
        It's driven by a belief that getting into your first home shouldn't depend on who you can
        turn to for help — and that the clever use of technology, AI, and data can make that depth
        of guidance the norm, not the exception.
      </p>

      <p>
        Guidy builds on more than two decades in technology — from hands-on engineering and
        architecture through to CIO and CTO leadership — across healthcare, government, security,
        and financial services in Europe and Oceania. This includes serving as CEO and leading the
        platform behind 6,000+ brokers and 60+ lender partners across Australia and New Zealand,
        scaling the business through a major acquisition that grew the customer base fourfold while
        maintaining its position as the industry's number one rated technology platform.
      </p>

      <p>
        I'm passionate about building products that delight customers and developing high-performing
        technology teams that drive business success.
      </p>

      <p>
        Outside of work, I'm a brewer, a rookie surfer, and a father of three. I write here about
        the things I'm learning and thinking about — technology, startups, leadership, AI, and
        occasionally the things that don't fit neatly into any category.
      </p>

    </div>

    <!-- Get in contact -->
    <div class="border-t border-border pt-10 mt-12">
      <h2 class="font-display text-2xl font-semibold text-text-primary mb-3">Get in touch</h2>
      <p class="font-body text-text-secondary mb-5 max-w-[480px]">
        Whether it's about Guidy, a potential collaboration, or just a conversation — I'd love to hear from you.
      </p>
      <a href="mailto:jakob@hgaard.com"
        class="inline-flex items-center gap-2 font-body text-accent font-medium no-underline hover:opacity-70 transition-opacity">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        jakob@hgaard.com
      </a>
      <div class="flex gap-6 mt-6">
        <a href="https://linkedin.com/in/jakobhojgaard" class="font-mono text-xs text-text-muted no-underline hover:text-accent transition-colors">LinkedIn</a>
        <a href="https://github.com/hgaard" class="font-mono text-xs text-text-muted no-underline hover:text-accent transition-colors">GitHub</a>
        <a href="https://x.com/hgaard" class="font-mono text-xs text-text-muted no-underline hover:text-accent transition-colors">X</a>
      </div>
    </div>
  </div>
</BaseLayout>
