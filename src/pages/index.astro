---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <div class="animate-fade-in">
    <!-- Hero -->
    <div class="py-20 pb-14 relative">
      <div class="absolute top-10 -right-5 w-44 h-44 rounded-full bg-accent-glow blur-[80px] opacity-40 pointer-events-none"></div>
      <p class="font-body text-sm text-accent tracking-[2px] uppercase mb-5 font-medium">
        Founder | Technologist | Executive Technology Advisor
      </p>
      <h1 class="font-display text-4xl md:text-[56px] font-semibold text-text-primary leading-[1.1] tracking-tight max-w-[680px] mb-6">
        Building things that matter.
      </h1>
      <p class="font-body text-[17px] text-text-secondary leading-relaxed max-w-[540px]">
        Jakob is a founder and seasoned technology leader with over two decades of experience — from hands-on engineering and architecture through to CIO and CTO leadership — spanning healthcare, government, security, and financial services across Europe and Oceania. Currently building a fintech venture focused on giving everyday Australians a simpler, smarter money experience. Driven by a belief that access and transparency in financial services shouldn't be the exception — and that the clever use of technology, AI, and data can make it the norm. This builds on years spent at the intersection of technology and financial services, including serving as CEO and leading the platform behind 6,000+ brokers and 60+ lender partners across Australia and New Zealand, scaling the business through a major acquisition that grew the customer base fourfold while maintaining its position as the industry's number one rated technology platform. Also available for executive advisory engagements through Bo & Hojgaard, helping organisations navigate AI adoption, cloud strategy, and technology leadership. Passionate about building products that delight customers and developing high-performing technology teams that drive business success.
      </p>
    </div>

    <!-- Get in contact -->
    <div class="border-t border-border pt-10 pb-5">
      <h2 class="font-display text-2xl font-semibold text-text-primary mb-3">Get in touch</h2>
      <p class="font-body text-text-secondary mb-5 max-w-[480px]">
        Whether it's about a potential collaboration, advisory work, or just a conversation — I'd love to hear from you.
      </p>
      <a href="mailto:jakob@hgaard.com"
        class="inline-flex items-center gap-2 font-body text-accent font-medium no-underline hover:opacity-70 transition-opacity">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        jakob@hgaard.com
      </a>
    </div>
  </div>
</BaseLayout>
