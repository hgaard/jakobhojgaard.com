---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);
---

<BaseLayout>
  <div class="animate-fade-in">
    <!-- Hero -->
    <div class="py-20 pb-14 relative">
      <div class="absolute top-10 -right-5 w-44 h-44 rounded-full bg-accent-glow blur-[80px] opacity-40 pointer-events-none"></div>
      <p class="font-body text-sm text-accent tracking-[2px] uppercase mb-5 font-medium">
        Founder | Technologist
      </p>
      <h1 class="font-display text-4xl md:text-[56px] font-semibold text-text-primary leading-[1.1] tracking-tight max-w-[680px] mb-6">
        Building things that matter.
      </h1>
      <p class="font-body text-[17px] text-text-secondary leading-relaxed max-w-[540px] mb-6">
        Founder of <strong class="text-text-primary font-semibold">Guidy</strong> — an end-to-end companion for everyday Australian first home buyers, built to be the knowledgeable presence they don't otherwise have. It builds on more than two decades in technology, from hands-on engineering through to CIO and CTO leadership across financial services.
      </p>
      <a href="/about" class="inline-flex items-center gap-1.5 font-body text-accent font-medium no-underline hover:opacity-70 transition-opacity">
        More about me
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>

    <!-- Writing -->
    {articles.length > 0 && (
      <div class="border-t border-border pt-10 pb-5">
        <div class="flex items-baseline justify-between mb-6">
          <h2 class="font-display text-2xl font-semibold text-text-primary">Writing</h2>
          <a href="/articles" class="font-mono text-xs text-text-muted no-underline hover:text-accent transition-colors">View all →</a>
        </div>
        <div class="space-y-6">
          {articles.map((article) => (
            <a href={`/articles/${article.id}`} class="block group no-underline">
              <div class="flex gap-3 items-center mb-1.5">
                <span class="font-mono text-[11px] text-accent tracking-wider uppercase font-semibold">{article.data.category}</span>
                <span class="text-border">·</span>
                <span class="font-mono text-xs text-text-muted">{article.data.date}</span>
                <span class="text-border">·</span>
                <span class="font-mono text-xs text-text-muted">{article.data.readTime} read</span>
              </div>
              <h3 class="font-display text-lg font-semibold text-text-primary tracking-tight group-hover:text-accent transition-colors">
                {article.data.title}
              </h3>
              {article.data.excerpt && (
                <p class="font-body text-sm text-text-secondary mt-1 leading-relaxed max-w-[560px]">
                  {article.data.excerpt}
                </p>
              )}
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</BaseLayout>
