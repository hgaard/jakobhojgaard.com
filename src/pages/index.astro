---
import BaseLayout from '../layouts/BaseLayout.astro';

// Get all MDX posts, sorted by date descending
const allPosts = await Astro.glob('./blog/*.mdx');
const posts = allPosts.sort((a, b) =>
  new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime()
);
const featured = posts.find(p => p.frontmatter.featured);
const rest = posts.filter(p => !p.frontmatter.featured);
---

<BaseLayout>
  <div class="animate-fade-in">
    <!-- Hero -->
    <div class="py-20 pb-14 relative">
      <div class="absolute top-10 -right-5 w-44 h-44 rounded-full bg-accent-glow blur-[80px] opacity-40 pointer-events-none"></div>
      <p class="font-body text-sm text-accent tracking-[2px] uppercase mb-5 font-medium">
        Thoughts on technology, fintech & leadership
      </p>
      <h1 class="font-display text-4xl md:text-[56px] font-semibold text-text-primary leading-[1.1] tracking-tight max-w-[680px] mb-6">
        Building things that matter in financial services.
      </h1>
      <p class="font-body text-[17px] text-text-secondary leading-relaxed max-w-[540px]">
        I'm a CIO turned founder, writing about the intersection of enterprise
        technology, mortgage innovation, and the craft of leading engineering
        teams. Based on the Sunshine Coast, Australia.
      </p>
    </div>

    <!-- Featured article -->
    {featured && (
      <a href={featured.url} class="block no-underline group mb-12">
        <div class="relative bg-surface border border-border rounded-xl p-10 transition-all duration-300 group-hover:-translate-y-0.5 group-hover:shadow-lg overflow-hidden">
          <div class="absolute top-0 left-0 h-[3px] bg-accent w-0 group-hover:w-full transition-all duration-400"></div>
          <div class="flex gap-3 items-center mb-4">
            <span class="font-mono text-[11px] text-accent tracking-wider uppercase bg-accent-subtle px-2.5 py-1 rounded font-semibold">Featured</span>
            <span class="font-mono text-[11px] text-text-muted tracking-wide">{featured.frontmatter.category}</span>
          </div>
          <h2 class="font-display text-[28px] font-semibold text-text-primary tracking-tight leading-snug mb-3">
            {featured.frontmatter.title}
          </h2>
          <p class="font-body text-[15px] text-text-secondary leading-relaxed max-w-[600px] mb-5">
            {featured.frontmatter.excerpt}
          </p>
          <div class="flex gap-4 items-center">
            <span class="font-mono text-xs text-text-muted">{featured.frontmatter.date}</span>
            <span class="text-border">·</span>
            <span class="font-mono text-xs text-text-muted">{featured.frontmatter.readTime} read</span>
          </div>
        </div>
      </a>
    )}

    <!-- Article list -->
    <div>
      {rest.map((post) => (
        <a href={post.url} class="block no-underline group border-b border-border py-7">
          <div class="flex justify-between items-start">
            <div class="flex-1 pr-6">
              <div class="flex gap-3 items-center mb-2.5">
                <span class="font-mono text-[11px] text-accent tracking-wide font-medium">{post.frontmatter.category}</span>
                <span class="font-mono text-[11px] text-text-muted">{post.frontmatter.date}</span>
              </div>
              <h3 class="font-display text-[19px] font-semibold text-text-primary tracking-tight leading-snug mb-2 group-hover:text-accent transition-colors">
                {post.frontmatter.title}
              </h3>
              <p class="font-body text-sm text-text-muted leading-relaxed max-w-[520px]">
                {post.frontmatter.excerpt.slice(0, 120)}…
              </p>
            </div>
            <span class="font-mono text-[11px] text-text-muted whitespace-nowrap pt-9">
              {post.frontmatter.readTime}
            </span>
          </div>
        </a>
      ))}
    </div>

    <!-- Newsletter CTA -->
    <div class="my-16 p-9 bg-surface border border-border rounded-xl flex justify-between items-center flex-wrap gap-5">
      <div>
        <h3 class="font-display text-xl font-semibold text-text-primary mb-1">Stay in the loop</h3>
        <p class="font-body text-sm text-text-muted">Occasional thoughts on fintech, engineering, and building products. No spam.</p>
      </div>
      <div class="flex gap-2">
        <input type="email" placeholder="your@email.com"
          class="font-body text-sm py-2.5 px-4 border border-border rounded-lg bg-bg text-text-primary outline-none w-[220px] focus:border-accent transition-colors" />
        <button class="font-mono text-xs font-semibold tracking-wide py-2.5 px-5 bg-text-primary text-bg border-none rounded-lg cursor-pointer hover:opacity-80 transition-opacity">
          Subscribe
        </button>
      </div>
    </div>
  </div>
</BaseLayout>
