---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
---

<BaseLayout title="Articles — Jakob Højgaard">
  <div class="animate-fade-in">
    <div class="py-14">
      <h1 class="font-display text-4xl font-semibold text-text-primary tracking-tight mb-4">Articles</h1>
      <p class="font-body text-text-secondary max-w-[480px]">
        Thoughts on fintech, engineering, leadership, and building things that matter.
      </p>
    </div>

    {articles.length === 0 ? (
      <p class="font-body text-text-muted">No published articles yet. Check back soon.</p>
    ) : (
      <div class="space-y-8 pb-16">
        {articles.map((article) => (
          <a href={`/articles/${article.id}`} class="block group no-underline">
            <div class="flex gap-3 items-center mb-2">
              <span class="font-mono text-[11px] text-accent tracking-wider uppercase font-semibold">{article.data.category}</span>
              <span class="text-border">·</span>
              <span class="font-mono text-xs text-text-muted">{article.data.date}</span>
              <span class="text-border">·</span>
              <span class="font-mono text-xs text-text-muted">{article.data.readTime} read</span>
            </div>
            <h2 class="font-display text-xl font-semibold text-text-primary tracking-tight group-hover:text-accent transition-colors">
              {article.data.title}
            </h2>
            <p class="font-body text-sm text-text-secondary mt-1.5 leading-relaxed max-w-[560px]">
              {article.data.excerpt}
            </p>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
