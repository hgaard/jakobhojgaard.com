---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro'
import SpeedInsights from "@vercel/speed-insights/astro"
interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
}

const {
  title = "Jakob Højgaard",
  description = "Danish technologist and founder of Guidy. Two decades in tech, from hands-on engineering to CIO and CTO leadership — writing on technology, AI, and leadership.",
  image,
  type = 'website',
  publishedTime,
} = Astro.props;

const siteName = "Jakob Højgaard";
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image ?? '/og-default.png', Astro.site);

// Person entity — the core of "who is Jakob Højgaard" for search and answer engines.
const person = {
  "@type": "Person",
  "@id": new URL('/#person', Astro.site).toString(),
  name: "Jakob Højgaard",
  url: Astro.site?.toString(),
  jobTitle: "Founder",
  description:
    "Danish technologist and founder of Guidy. More than two decades in technology, from hands-on engineering through CIO and CTO leadership across financial services.",
  sameAs: [
    "https://linkedin.com/in/jakobhojgaard",
    "https://github.com/hgaard",
    "https://x.com/hgaard",
  ],
};

const jsonLd =
  type === 'article'
    ? {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        headline: title,
        description,
        image: ogImageURL.toString(),
        datePublished: publishedTime,
        url: canonicalURL.toString(),
        mainEntityOfPage: canonicalURL.toString(),
        author: person,
        publisher: person,
      }
    : {
        "@context": "https://schema.org",
        "@graph": [
          person,
          {
            "@type": "WebSite",
            "@id": new URL('/#website', Astro.site).toString(),
            url: Astro.site?.toString(),
            name: siteName,
            description,
            publisher: { "@id": new URL('/#person', Astro.site).toString() },
          },
        ],
      };
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Jakob Højgaard" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content="en_US" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:creator" content="@hgaard" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <SpeedInsights />
    <Analytics />
  </head>
  <body class="bg-bg min-h-screen font-body">
    <!-- Subtle grain overlay -->
    <div class="fixed inset-0 pointer-events-none z-0 opacity-[0.025]"
      style="background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E&quot;); background-repeat: repeat; background-size: 256px 256px;">
    </div>

    <div class="max-w-[760px] mx-auto px-6 relative z-10">
      <!-- Navigation -->
      <nav class="flex justify-between items-center py-7 border-b border-border">
        <a href="/" class="flex items-baseline gap-2.5 no-underline">
          <span class="font-display text-[22px] font-semibold text-text-primary tracking-tight">Jakob Højgaard</span>
        </a>
        <div class="flex gap-6">
          <a href="/articles" class="font-mono text-xs text-text-muted no-underline hover:text-accent transition-colors">Articles</a>
          <a href="/about" class="font-mono text-xs text-text-muted no-underline hover:text-accent transition-colors">About</a>
        </div>
      </nav>

      <!-- Content -->
      <main>
        <slot />
      </main>

      <!-- Footer -->
      <footer class="border-t border-border py-8 mt-16 flex justify-between items-center">
        <span class="font-mono text-xs text-text-muted">© 2026 Jakob Højgaard</span>
        <div class="flex gap-6">
          <a href="https://linkedin.com/in/jakobhojgaard" class="font-mono text-xs text-text-muted no-underline hover:text-accent transition-colors">LinkedIn</a>
          <a href="https://github.com/hgaard" class="font-mono text-xs text-text-muted no-underline hover:text-accent transition-colors">GitHub</a>
          <a href="https://x.com/hgaard" class="font-mono text-xs text-text-muted no-underline hover:text-accent transition-colors">X</a>
        </div>
      </footer>
    </div>
  </body>
</html>
